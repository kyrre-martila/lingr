generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  paused
  deleted
  restricted
}

enum SessionStatus {
  active
  revoked
  expired
}

enum GlimpsState {
  draft
  published
  expired
  archived
}

enum SparkState {
  potential
  invited
  accepted
  paused
  declined
  expired
}

enum ConversationState {
  active
  paused
  closed
}

enum ConversationParticipantRole {
  member
  system
}

enum MessageType {
  text
  system
  layer_unlock
  playing_now
  app_invite
}

enum MessageVisibility {
  conversation
  soft_banner
}

enum MessageDeliveryState {
  queued
  sent
  failed
}

enum AppId {
  match_cards
  guess_me
  snuggle
  playing_now
}

enum AppSessionLifecycle {
  invite
  accept
  active
  complete
  dismissed
}


model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  authSubjectRef     String?    @unique
  status             UserStatus @default(active)
  isEmailVerified    Boolean    @default(false)
  profile            Profile?
  sessions           Session[]
  glimpses           Glimps[]
  initiatedSparks    Spark[]   @relation("SparkInitiator")
  receivedSparks     Spark[]   @relation("SparkRecipient")
  conversationParticipants ConversationParticipant[]
  sentMessages       Message[]
  relationshipLayersAsPrimary RelationshipLayer[] @relation("RelationshipLayerPrimary")
  relationshipLayersAsSecondary RelationshipLayer[] @relation("RelationshipLayerSecondary")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  pausedAt           DateTime?
  deletedAt          DateTime?

  @@map("users")
}

model RelationshipLayer {
  id                  String   @id @default(cuid())
  primaryUserId       String
  secondaryUserId     String
  currentLayer        Int      @default(0)
  reciprocalMessageCount Int   @default(0)
  lastMessageSenderId String?
  lastCountedMessageAt DateTime?
  layer1UnlockedAt    DateTime?
  layer2UnlockedAt    DateTime?
  layer3UnlockedAt    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  primaryUser         User     @relation("RelationshipLayerPrimary", fields: [primaryUserId], references: [id], onDelete: Cascade)
  secondaryUser       User     @relation("RelationshipLayerSecondary", fields: [secondaryUserId], references: [id], onDelete: Cascade)

  @@unique([primaryUserId, secondaryUserId])
  @@index([primaryUserId, secondaryUserId, currentLayer])
  @@map("relationship_layers")
}

model Glimps {
  id            String      @id @default(cuid())
  userId        String
  reflection    String
  mood          String
  prompt        String?
  imageNote     String?
  privacy       String
  emotionalTone String
  state         GlimpsState @default(draft)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  archivedAt    DateTime?

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, state, createdAt])
  @@map("glimpses")
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  displayName         String
  pronouns            String?
  ageRange            String?
  bio                 String?
  layersSummary       String?
  locationRegion      String?
  broadRegion         String?
  revealInterests     Json?
  revealEmotionalValues Json?
  avatarAssetId       String?
  profileCompleteness Int      @default(0)
  visibility          String   @default("discoverable")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id          String        @id @default(cuid())
  userId      String
  status      SessionStatus @default(active)
  tokenHash   String        @unique
  expiresAt   DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("sessions")
}


model Spark {
  id                   String     @id @default(cuid())
  initiatorUserId      String
  recipientUserId      String
  pairMinUserId        String
  pairMaxUserId        String
  status               SparkState @default(invited)
  sourceGlimpsId       String?
  softResonanceContext String?
  expiresAt            DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  respondedAt          DateTime?
  pausedAt             DateTime?
  declinedAt           DateTime?
  expiredAt            DateTime?

  initiator            User       @relation("SparkInitiator", fields: [initiatorUserId], references: [id], onDelete: Cascade)
  recipient            User       @relation("SparkRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  conversation         Conversation?

  @@index([initiatorUserId, recipientUserId, status])
  @@index([pairMinUserId, pairMaxUserId, status])
  @@index([recipientUserId, status, createdAt])
  @@map("sparks")
}

model Conversation {
  id              String                    @id @default(cuid())
  sparkId         String                    @unique
  state           ConversationState         @default(active)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  spark           Spark                     @relation(fields: [sparkId], references: [id], onDelete: Cascade)
  participants    ConversationParticipant[]
  messages        Message[]
  appSessions     AppSession[]

  @@index([state, updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id              String                      @id @default(cuid())
  conversationId  String
  userId          String
  role            ConversationParticipantRole @default(member)
  joinedAt        DateTime                    @default(now())

  conversation    Conversation                @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, joinedAt])
  @@map("conversation_participants")
}

model Message {
  id              String                @id @default(cuid())
  conversationId  String
  senderUserId    String?
  type            MessageType
  visibility      MessageVisibility     @default(conversation)
  deliveryState   MessageDeliveryState  @default(sent)
  content         Json
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  conversation    Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User?                 @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}



model AppSession {
  id                String              @id @default(cuid())
  conversationId    String
  appId             AppId
  lifecycle         AppSessionLifecycle @default(invite)
  invitedByUserId   String
  acceptedByUserId  String?
  completedByUserId String?
  dismissedByUserId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  conversation      Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  matchCardsSession MatchCardsSession?
  guessMeSession    GuessMeSession?
  snuggleSession    SnuggleSession?

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("app_sessions")
}

model MatchCardsSession {
  id               String   @id @default(cuid())
  appSessionId     String   @unique
  conversationId   String
  state            String
  questionId       String
  questionPromptKey String
  questionTone     String
  answerByInviter  String?
  answerByInvitee  String?
  revealState      String
  completed        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appSession       AppSession @relation(fields: [appSessionId], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("match_cards_sessions")
}



model GuessMeSession {
  id                 String   @id @default(cuid())
  appSessionId       String   @unique
  conversationId     String
  state              String
  promptId           String
  promptKey          String
  optionKeys         String[]
  ownAnswerByInviter String?
  ownAnswerByInvitee String?
  guessByInviter     String?
  guessByInvitee     String?
  revealState        String
  completed          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appSession         AppSession   @relation(fields: [appSessionId], references: [id], onDelete: Cascade)
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("guess_me_sessions")
}

model SnuggleSession {
  id               String   @id @default(cuid())
  appSessionId     String   @unique
  conversationId   String
  state            String
  holdByInviter    Boolean  @default(false)
  holdByInvitee    Boolean  @default(false)
  sharedMomentState String
  completionReason String?
  completed        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appSession       AppSession   @relation(fields: [appSessionId], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("snuggle_sessions")
}

model BlockRelation {
  id            String   @id @default(cuid())
  blockerUserId String
  blockedUserId String
  createdAt     DateTime @default(now())

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId, blockerUserId])
  @@map("block_relations")
}

model DiscoveryView {
  id               String   @id @default(cuid())
  viewerUserId     String
  discoveredUserId String
  firstSeenDayKey  String
  createdAt        DateTime @default(now())

  @@unique([viewerUserId, discoveredUserId])
  @@index([viewerUserId, firstSeenDayKey])
  @@map("discovery_views")
}

model DiscoveryDailyTracker {
  id              String   @id @default(cuid())
  viewerUserId    String
  dayKey          String
  introducedCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([viewerUserId, dayKey])
  @@index([viewerUserId, createdAt])
  @@map("discovery_daily_trackers")
}

enum RegionLaunchStatus {
  closed
  waitlist
  open
  paused
}

model Country {
  id        String   @id @default(cuid())
  isoCode   String   @unique
  name      String
  enabled   Boolean  @default(true)
  regions   Region[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("countries")
}

model Region {
  id           String             @id @default(cuid())
  countryId    String
  slug         String
  name         String
  launchStatus RegionLaunchStatus @default(closed)
  launchDate   DateTime?
  isOpen       Boolean            @default(false)
  voteCount    Int                @default(0)
  country      Country            @relation(fields: [countryId], references: [id], onDelete: Cascade)
  votes        RegionInterestVote[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([countryId, slug])
  @@map("regions")
}

model RegionInterestVote {
  id        String   @id @default(cuid())
  regionId  String
  email     String
  firstName String?
  locale    String   @default("en")
  createdAt DateTime @default(now())
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, email])
  @@map("region_interest_votes")
}
