{
  "name": "lingr",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "node --watch apps/api/src/server.js",
    "start:api": "node apps/api/src/server.js",
    "dev:web": "npm run dev --workspace @lingr/web",
    "build:web": "npm run build --workspace @lingr/web",
    "start:web": "npm run start --workspace @lingr/web",
    "lint:web": "npm run lint --workspace @lingr/web",
    "build:api": "npm run db:generate --workspace @lingr/api",
    "smoke:api": "npm run e2e:smoke --workspace @lingr/api"
  }
}
